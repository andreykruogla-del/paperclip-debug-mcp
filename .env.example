# Core configuration
PAPERCLIP_BASE_URL=https://paperclip.example.com
PAPERCLIP_TOKEN=replace-with-bearer-token
PAPERCLIP_COMPANY_ID=replace-with-company-id
PAPERCLIP_PROJECT_ID=replace-with-project-id
PAPERCLIP_ISSUE_IDS=
PAPERCLIP_MAX_ISSUES=25
PAPERCLIP_COLLECTOR_ENABLED=true
DOCKER_COLLECTOR_ENABLED=true
MCP_HTTP_PORT=8787
MCP_HTTP_AUTH_TOKEN=

# Optional adapters configuration
FILE_COLLECTOR_ENABLED=false
FILE_COLLECTOR_PATHS=
FILE_COLLECTOR_MAX_LINES=300
FILE_COLLECTOR_INCLUDE_PATTERN=error|exception|failed|timeout|refused|unauthor
WORDPRESS_COLLECTOR_ENABLED=false
WORDPRESS_BASE_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
