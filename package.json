{
  "name": "paperclip-debug-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP-first debugging and incident intelligence layer for Paperclip agent systems",
  "type": "module",
  "scripts": {
    "clean": "tsx scripts/clean.ts",
    "build": "npm run clean && npx tsc -p tsconfig.json",
    "mcp:stdio": "tsx scripts/mcp-stdio.ts",
    "mcp:http": "tsx scripts/mcp-http.ts",
    "check": "npx tsc -p tsconfig.json --noEmit",
    "smoke:live": "tsx scripts/smoke-live.ts",
    "doctor": "tsx scripts/doctor.ts",
    "incident:packet": "tsx scripts/build-incident-packet.ts",
    "benchmark:report": "tsx scripts/benchmark-report.ts",
    "collector:new": "tsx scripts/new-collector.ts",
    "test": "vitest run"
  },
  "keywords": [
    "paperclip",
    "mcp",
    "debugging",
    "incident",
    "agents",
    "hermes",
    "openclaw",
    "opencode"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.2.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
